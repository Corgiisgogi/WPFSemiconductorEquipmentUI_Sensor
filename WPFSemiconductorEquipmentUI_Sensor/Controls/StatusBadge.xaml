<UserControl x:Class="WPFSemiconductorEquipmentUI_Sensor.Controls.StatusBadge"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             MinHeight="20">
    <Grid MinHeight="20">
        <Border x:Name="BadgeBorder"
                CornerRadius="13"
                Background="{StaticResource BrushSurfaceSubtle}" />

        <TextBox x:Name="BadgeTextBox"
                 Text="{Binding Text, RelativeSource={RelativeSource AncestorType=UserControl}}"
                 TextAlignment="{Binding TextAlignment, RelativeSource={RelativeSource AncestorType=UserControl}}"
                 MinWidth="0"
                 MinHeight="0"
                 Height="Auto"
                 Padding="10,0"
                 BorderThickness="0"
                 Background="Transparent"
                 FontSize="12"
                 FontWeight="SemiBold"
                 Foreground="{StaticResource BrushTextSecondary}"
                 VerticalContentAlignment="Center"
                 IsReadOnly="True"
                 IsReadOnlyCaretVisible="False"
                 Focusable="False"
                 IsHitTestVisible="False" />
    </Grid>
</UserControl>
