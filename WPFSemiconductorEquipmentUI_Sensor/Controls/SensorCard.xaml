<UserControl x:Class="WPFSemiconductorEquipmentUI_Sensor.Controls.SensorCard"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:WPFSemiconductorEquipmentUI_Sensor.Controls"
             Width="252"
             Height="146">
    <Border Style="{StaticResource CardBorderStyle}" Padding="16">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <DockPanel Grid.Row="0">
                <controls:StatusBadge DockPanel.Dock="Right"
                                      Text="{Binding BadgeText, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                      Tone="{Binding Tone, RelativeSource={RelativeSource AncestorType=UserControl}}" />
                <TextBlock Text="{Binding Title, RelativeSource={RelativeSource AncestorType=UserControl}}"
                           Style="{StaticResource BodyStrongText}"
                           VerticalAlignment="Center" />
            </DockPanel>

            <StackPanel Grid.Row="1" Orientation="Horizontal" VerticalAlignment="Center">
                <TextBlock Text="{Binding Value, RelativeSource={RelativeSource AncestorType=UserControl}}"
                           FontSize="34"
                           FontWeight="Bold"
                           Foreground="{StaticResource BrushTextPrimary}" />
                <TextBlock Text="{Binding Unit, RelativeSource={RelativeSource AncestorType=UserControl}}"
                           Margin="6,16,0,0"
                           Style="{StaticResource BodyStrongText}" />
            </StackPanel>

            <TextBlock Grid.Row="2"
                       Text="{Binding RangeText, RelativeSource={RelativeSource AncestorType=UserControl}}"
                       Style="{StaticResource CaptionText}" />

            <Border Grid.Row="3"
                    Height="8"
                    Margin="0,8,0,0"
                    CornerRadius="4"
                    Background="{StaticResource BrushSurfaceSubtle}">
                <Rectangle Width="{Binding IndicatorWidth, RelativeSource={RelativeSource AncestorType=UserControl}}"
                           HorizontalAlignment="Left"
                           RadiusX="4"
                           RadiusY="4"
                           Fill="{Binding IndicatorBrush, RelativeSource={RelativeSource AncestorType=UserControl}}" />
            </Border>
        </Grid>
    </Border>
</UserControl>
