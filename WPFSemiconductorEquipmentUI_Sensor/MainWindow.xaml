<Window x:Class="WPFSemiconductorEquipmentUI_Sensor.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:views="clr-namespace:WPFSemiconductorEquipmentUI_Sensor.Views"
        xmlns:viewModels="clr-namespace:WPFSemiconductorEquipmentUI_Sensor.ViewModels"
        xmlns:controls="clr-namespace:WPFSemiconductorEquipmentUI_Sensor.Controls"
        mc:Ignorable="d"
        Title="반도체 장비 제어"
        Width="1440"
        Height="900"
        MinWidth="1440"
        MinHeight="900"
        WindowStartupLocation="CenterScreen"
        Background="#F3F4F6">
    <Window.Resources>
        <DataTemplate DataType="{x:Type viewModels:LoginViewModel}">
            <views:LoginView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type viewModels:PendingViewModel}">
            <views:PendingView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type viewModels:ConsoleViewModel}">
            <views:ConsoleView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type viewModels:LogsViewModel}">
            <views:LogsView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type viewModels:SettingsViewModel}">
            <views:SettingsView />
        </DataTemplate>

        <Style x:Key="BottomNavigationButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="58" />
            <Setter Property="MinWidth" Value="190" />
            <Setter Property="Background" Value="#F8FAFC" />
            <Setter Property="BorderBrush" Value="#B8C0CC" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsSelected}" Value="True">
                    <Setter Property="Background" Value="#0B70B7" />
                    <Setter Property="BorderBrush" Value="#075B95" />
                </DataTrigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="52" />
            <RowDefinition Height="*" />
            <RowDefinition Height="75" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="#F8FAFC" BorderBrush="#C5CBD3" BorderThickness="0,0,0,1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="300" />
                    <ColumnDefinition Width="140" />
                    <ColumnDefinition Width="180" />
                    <ColumnDefinition Width="110" />
                    <ColumnDefinition Width="190" />
                    <ColumnDefinition Width="130" />
                    <ColumnDefinition Width="230" />
                    <ColumnDefinition Width="150" />
                </Grid.ColumnDefinitions>
                <StackPanel Orientation="Horizontal" Margin="16,0,0,0" VerticalAlignment="Center">
                    <Border Width="30" Height="30" Background="#D1D5DB" BorderBrush="#6B7280" BorderThickness="1" Margin="0,0,12,0" />
                    <TextBlock Text="SEMI CONTROL" FontSize="22" FontWeight="Bold" Foreground="#111827" VerticalAlignment="Center" />
                    <TextBlock Text=" SIM-01" FontSize="20" FontWeight="SemiBold" Foreground="#374151" VerticalAlignment="Center" />
                </StackPanel>
                <Border Grid.Column="1" BorderBrush="#D1D5DB" BorderThickness="1,0,0,0" Padding="14,0">
                    <TextBlock Text="MODE: MANUAL" VerticalAlignment="Center" FontSize="14" Foreground="#111827" />
                </Border>
                <Border Grid.Column="2" BorderBrush="#D1D5DB" BorderThickness="1,0,0,0" Padding="14,0">
                    <TextBlock Text="{Binding Session.UserId, StringFormat=USER: {0}}" VerticalAlignment="Center" FontSize="14" Foreground="#111827" />
                </Border>
                <Border Grid.Column="3" BorderBrush="#D1D5DB" BorderThickness="1,0,0,0" Padding="14,0">
                    <TextBlock Text="PLC: RUN" VerticalAlignment="Center" FontSize="14" Foreground="#047857" FontWeight="SemiBold" />
                </Border>
                <Border Grid.Column="4" BorderBrush="#D1D5DB" BorderThickness="1,0,0,0" Padding="14,0">
                    <TextBlock Text="EtherCAT: CONNECTED" VerticalAlignment="Center" FontSize="14" Foreground="#047857" FontWeight="SemiBold" />
                </Border>
                <Border Grid.Column="5" BorderBrush="#D1D5DB" BorderThickness="1,0,0,0" Padding="14,0">
                    <TextBlock Text="ADS: OK" VerticalAlignment="Center" FontSize="14" Foreground="#047857" FontWeight="SemiBold" />
                </Border>
                <Border Grid.Column="6" BorderBrush="#D1D5DB" BorderThickness="1,0,0,0" Padding="14,0">
                    <TextBlock Text="{Binding CurrentTimeText}" VerticalAlignment="Center" HorizontalAlignment="Center" FontSize="14" FontWeight="SemiBold" Foreground="#111827" TextWrapping="NoWrap" />
                </Border>
                <Border Grid.Column="7" BorderBrush="#D1D5DB" BorderThickness="1,0,0,0" Padding="10,0">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                        <TextBlock Text="ALERT" FontSize="14" FontWeight="Bold" Foreground="#B45309" VerticalAlignment="Center" Margin="0,0,8,0" />
                        <controls:StatusBadge Text="{Binding AlertSummaryText}" Tone="{Binding AlertSummaryTone}" Width="78" />
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <ContentControl Grid.Row="1" Margin="10" Content="{Binding CurrentViewModel}" />

        <Border Grid.Row="2" Background="#F8FAFC" BorderBrush="#C5CBD3" BorderThickness="0,1,0,0" Padding="8">
            <ItemsControl ItemsSource="{Binding NavigationItems}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <UniformGrid Rows="1" />
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Button Style="{StaticResource BottomNavigationButtonStyle}"
                                Visibility="{Binding Visibility}"
                                Command="{Binding DataContext.NavigateCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                CommandParameter="{Binding}">
                            <TextBlock Text="{Binding Title}" FontSize="22" FontWeight="Bold">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Foreground" Value="#111827" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                                <Setter Property="Foreground" Value="White" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </Button>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </Border>
    </Grid>
</Window>
