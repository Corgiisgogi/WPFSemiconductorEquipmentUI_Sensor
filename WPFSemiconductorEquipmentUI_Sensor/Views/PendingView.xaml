<UserControl x:Class="WPFSemiconductorEquipmentUI_Sensor.Views.PendingView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:WPFSemiconductorEquipmentUI_Sensor.Controls">
    <StackPanel>
        <DockPanel>
            <StackPanel>
                <TextBlock Text="{Binding Title}" Style="{StaticResource PageTitleText}" />
                <TextBlock Text="{Binding Description}" Style="{StaticResource BodyText}" />
            </StackPanel>
            <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                <controls:StatusBadge Text="CONTROL LOCKED" Tone="Disabled" Margin="0,0,8,0" />
                <controls:StatusBadge Text="AUDIT LOG ON" Tone="Blue" />
            </StackPanel>
        </DockPanel>

        <Border Margin="0,18,0,0" CornerRadius="8" Background="{StaticResource BrushWarningSoft}" BorderBrush="#E7C26A" BorderThickness="1" Padding="16">
            <DockPanel>
                <controls:StatusBadge Text="PENDING" Tone="Warning" Margin="0,0,14,0" />
                <TextBlock Text="Unapproved users cannot run START, STOP, or FORCE SHUTDOWN actions."
                           Style="{StaticResource BodyStrongText}"
                           TextWrapping="Wrap" />
            </DockPanel>
        </Border>

        <Grid Margin="0,18,0,0" MinHeight="592">
            <Grid.RowDefinitions>
                <RowDefinition Height="220" />
                <RowDefinition Height="18" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition />
                <ColumnDefinition Width="18" />
                <ColumnDefinition />
                <ColumnDefinition Width="18" />
                <ColumnDefinition />
            </Grid.ColumnDefinitions>

            <Border Style="{StaticResource CardBorderStyle}">
                <StackPanel>
                    <controls:StatusBadge Text="PENDING" Tone="Warning" HorizontalAlignment="Left" />
                    <TextBlock Text="Waiting for approval" Margin="0,16,0,0" Style="{StaticResource SectionTitleText}" />
                    <TextBlock Text="Login stays limited and control buttons remain disabled."
                               Margin="0,10,0,18"
                               Style="{StaticResource BodyText}"
                               TextWrapping="Wrap" />
                    <StackPanel Orientation="Horizontal">
                        <Button Content="START" Style="{StaticResource DisabledButtonStyle}" Width="80" />
                        <Button Content="STOP" Style="{StaticResource DisabledButtonStyle}" Width="80" Margin="8,0,0,0" />
                        <Button Content="LOCKED" Style="{StaticResource DisabledButtonStyle}" Width="80" Margin="8,0,0,0" />
                    </StackPanel>
                </StackPanel>
            </Border>

            <Border Grid.Column="2" Style="{StaticResource CardBorderStyle}">
                <StackPanel>
                    <controls:StatusBadge Text="REJECTED" Tone="Danger" HorizontalAlignment="Left" />
                    <TextBlock Text="Request rejected" Margin="0,16,0,0" Style="{StaticResource SectionTitleText}" />
                    <TextBlock Text="The account remains recorded, but console entry is blocked."
                               Margin="0,10,0,18"
                               Style="{StaticResource BodyText}"
                               TextWrapping="Wrap" />
                    <StackPanel Orientation="Horizontal">
                        <Button Content="START" Style="{StaticResource DisabledButtonStyle}" Width="80" />
                        <Button Content="STOP" Style="{StaticResource DisabledButtonStyle}" Width="80" Margin="8,0,0,0" />
                        <Button Content="LOCKED" Style="{StaticResource DisabledButtonStyle}" Width="80" Margin="8,0,0,0" />
                    </StackPanel>
                </StackPanel>
            </Border>

            <Border Grid.Column="4" Style="{StaticResource CardBorderStyle}">
                <StackPanel>
                    <controls:StatusBadge Text="LOGIN BLOCK" Tone="Disabled" HorizontalAlignment="Left" />
                    <TextBlock Text="Control blocked" Margin="0,16,0,0" Style="{StaticResource SectionTitleText}" />
                    <TextBlock Text="Equipment controls are visibly locked to prevent mistaken operation."
                               Margin="0,10,0,18"
                               Style="{StaticResource BodyText}"
                               TextWrapping="Wrap" />
                    <StackPanel Orientation="Horizontal">
                        <Button Content="START" Style="{StaticResource DisabledButtonStyle}" Width="80" />
                        <Button Content="STOP" Style="{StaticResource DisabledButtonStyle}" Width="80" Margin="8,0,0,0" />
                        <Button Content="LOCKED" Style="{StaticResource DisabledButtonStyle}" Width="80" Margin="8,0,0,0" />
                    </StackPanel>
                </StackPanel>
            </Border>

            <Border Grid.Row="2" Grid.ColumnSpan="2" Style="{StaticResource CardBorderStyle}">
                <StackPanel>
                    <TextBlock Text="Approval process" Style="{StaticResource SectionTitleText}" />
                    <TextBlock Text="1. Sign up request" Margin="0,18,0,0" Style="{StaticResource BodyText}" />
                    <TextBlock Text="2. Pending state" Margin="0,12,0,0" Foreground="{StaticResource BrushWarning}" FontWeight="SemiBold" />
                    <TextBlock Text="3. Admin review" Margin="0,12,0,0" Style="{StaticResource BodyText}" />
                    <TextBlock Text="4. Approve or reject" Margin="0,12,0,0" Style="{StaticResource BodyText}" />
                    <TextBlock Text="5. Approved login only" Margin="0,12,0,0" Style="{StaticResource BodyText}" />
                </StackPanel>
            </Border>

            <Border Grid.Row="2" Grid.Column="2" Grid.ColumnSpan="3" Style="{StaticResource CardBorderStyle}">
                <StackPanel>
                    <TextBlock Text="Permission boundary" Style="{StaticResource SectionTitleText}" />
                    <UniformGrid Columns="2" Margin="0,18,0,0">
                        <TextBlock Text="Run / stop equipment" Style="{StaticResource BodyStrongText}" />
                        <TextBlock Text="Approved user only" Style="{StaticResource BodyText}" />
                        <TextBlock Text="View live sensors" Margin="0,14,0,0" Style="{StaticResource BodyStrongText}" />
                        <TextBlock Text="Approved user + admin" Margin="0,14,0,0" Style="{StaticResource BodyText}" />
                        <TextBlock Text="Approve accounts" Margin="0,14,0,0" Style="{StaticResource BodyStrongText}" />
                        <TextBlock Text="Admin web only" Margin="0,14,0,0" Style="{StaticResource BodyText}" />
                        <TextBlock Text="Remote shutdown" Margin="0,14,0,0" Style="{StaticResource BodyStrongText}" />
                        <TextBlock Text="Admin + risk rule" Margin="0,14,0,0" Style="{StaticResource BodyText}" />
                    </UniformGrid>
                </StackPanel>
            </Border>
        </Grid>
    </StackPanel>
</UserControl>
