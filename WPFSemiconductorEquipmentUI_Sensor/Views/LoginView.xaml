<UserControl x:Class="WPFSemiconductorEquipmentUI_Sensor.Views.LoginView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:WPFSemiconductorEquipmentUI_Sensor.Controls">
    <StackPanel>
        <DockPanel>
            <StackPanel>
                <TextBlock Text="{Binding Title}" Style="{StaticResource PageTitleText}" />
                <TextBlock Text="{Binding Description}" Style="{StaticResource BodyText}" />
            </StackPanel>
            <StackPanel  DockPanel.Dock="Right" Orientation="Horizontal" HorizontalAlignment="Right">
                <controls:StatusBadge Text="DB CONNECTED" Tone="Normal" Margin="0,0,8,0" />
                <controls:StatusBadge Text="{Binding AuthStatusText}" Tone="{Binding AuthStatusTone}" />
            </StackPanel>
        </DockPanel>

        <Grid Margin="0,18,0,0" MinHeight="640">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="500" />
                <ColumnDefinition Width="24" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border Style="{StaticResource CardBorderStyle}" Padding="28">
                <StackPanel>
                    <controls:StatusBadge Text="CONTROL SYSTEM" Tone="Blue" HorizontalAlignment="Left" />
                    <TextBlock Text="Semiconductor Equipment Control"
                               Margin="0,18,0,0"
                               FontSize="28"
                               FontWeight="Bold"
                               Foreground="{StaticResource BrushTextPrimary}"
                               TextWrapping="Wrap" />
                    <TextBlock Text="Local WPF console for approved operators, live sensor checks, and controlled equipment actions."
                               Margin="0,18,0,0"
                               Style="{StaticResource BodyText}" />
                    <Border Margin="0,24,0,0" Padding="16" CornerRadius="8" Background="{StaticResource BrushSurfaceSubtle}">
                        <StackPanel>
                            <TextBlock Text="Access path" Style="{StaticResource BodyStrongText}" />
                            <TextBlock Text="01  Sign up request" Margin="0,12,0,0" Style="{StaticResource CaptionText}" />
                            <TextBlock Text="02  Admin approval" Margin="0,8,0,0" Style="{StaticResource CaptionText}" />
                            <TextBlock Text="03  Console access" Margin="0,8,0,0" Style="{StaticResource CaptionText}" />
                        </StackPanel>
                    </Border>
                    <StackPanel Orientation="Horizontal" Margin="0,18,0,0">
                        <controls:StatusBadge Text="EtherCAT READY" Tone="Normal" Margin="0,0,8,0" />
                        <controls:StatusBadge Text="SQLite SYNC" Tone="Normal" Margin="0,0,8,0" />
                        <controls:StatusBadge Text="AI WATCH" Tone="Warning" />
                    </StackPanel>
                </StackPanel>
            </Border>

            <Border Grid.Column="2" Style="{StaticResource CardBorderStyle}" Padding="28">
                <StackPanel>
                    <DockPanel>
                        <StackPanel>
                            <TextBlock Text="Operator Access" FontSize="24" FontWeight="Bold" Foreground="{StaticResource BrushTextPrimary}" />
                            <TextBlock Text="Login and sign up are separated to prevent account flow mistakes."
                                       Margin="0,12,0,0"
                                       Style="{StaticResource BodyText}" />
                        </StackPanel>
                        <controls:StatusBadge DockPanel.Dock="Right" Text="{Binding AuthStatusText}" Tone="{Binding AuthStatusTone}" />
                    </DockPanel>

                    <DockPanel Margin="0,18,0,0">
                        <TextBlock Text="Current session" Style="{StaticResource BodyStrongText}" />
                        <controls:StatusBadge DockPanel.Dock="Right"
                                              Text="{Binding Session.UserStateText}"
                                              Tone="{Binding Session.UserStateTone}"
                                              Width="112"
                                              HorizontalAlignment="Right" />
                    </DockPanel>
                    <DockPanel Margin="0,10,0,0">
                        <TextBlock Text="{Binding Session.UserId}" Style="{StaticResource BodyStrongText}" />
                        <controls:StatusBadge DockPanel.Dock="Right"
                                              Text="{Binding Session.RoleText}"
                                              Tone="Blue"
                                              Width="112"
                                              HorizontalAlignment="Right" />
                    </DockPanel>

                    <Border Margin="0,18,0,0" Padding="6" CornerRadius="8" Background="{StaticResource BrushSurfaceSubtle}">
                        <UniformGrid Columns="2">
                            <Button Content="LOGIN"
                                    Command="{Binding ShowLoginCommand}"
                                    Style="{StaticResource CompactButtonStyle}"
                                    Margin="0,0,6,0" />
                            <Button Content="SIGN UP"
                                    Command="{Binding ShowSignUpCommand}"
                                    Style="{StaticResource CompactButtonStyle}"
                                    Margin="6,0,0,0" />
                        </UniformGrid>
                    </Border>
                    <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                        <controls:StatusBadge Text="LOGIN MODE" Tone="{Binding LoginModeTone}" Margin="0,0,8,0" />
                        <controls:StatusBadge Text="SIGN UP MODE" Tone="{Binding SignUpModeTone}" />
                    </StackPanel>

                    <StackPanel Margin="0,18,0,0" Visibility="{Binding LoginPanelVisibility}">
                        <TextBlock Text="Operator Login" Style="{StaticResource SectionTitleText}" />
                        <TextBlock Text="Use an approved account to unlock equipment controls. Pending or rejected accounts stay locked."
                                   Margin="0,8,0,0"
                                   Style="{StaticResource BodyText}"
                                   TextWrapping="Wrap" />
                        <TextBlock Text="User ID" Margin="0,18,0,6" Style="{StaticResource CaptionText}" />
                        <TextBox Text="{Binding LoginUserId, UpdateSourceTrigger=PropertyChanged}" />
                        <TextBlock Text="Password" Margin="0,14,0,6" Style="{StaticResource CaptionText}" />
                        <PasswordBox x:Name="LoginPasswordInput" PasswordChanged="OnLoginPasswordChanged" Height="40" Padding="12,0" VerticalContentAlignment="Center" />
                        <WrapPanel Margin="0,18,0,0">
                            <Button Content="LOGIN" Command="{Binding LoginCommand}" Style="{StaticResource PrimaryButtonStyle}" Width="132" Margin="0,0,12,10" />
                            <Button Content="CHECK STATUS" Command="{Binding CheckStatusCommand}" Style="{StaticResource CompactButtonStyle}" Width="132" Margin="0,0,12,10" />
                            <Button Content="LOGOUT" Command="{Binding LogoutCommand}" Style="{StaticResource CompactButtonStyle}" Width="112" Margin="0,0,0,10" />
                        </WrapPanel>
                    </StackPanel>

                    <StackPanel Margin="0,18,0,0" Visibility="{Binding SignUpPanelVisibility}">
                        <TextBlock Text="Create Account Request" Style="{StaticResource SectionTitleText}" />
                        <TextBlock Text="Submit a new account request. The account cannot control equipment until the web admin approves it."
                                   Margin="0,8,0,0"
                                   Style="{StaticResource BodyText}"
                                   TextWrapping="Wrap" />
                        <TextBlock Text="User ID" Margin="0,18,0,6" Style="{StaticResource CaptionText}" />
                        <TextBox Text="{Binding RegisterUserId, UpdateSourceTrigger=PropertyChanged}" />
                        <TextBlock Text="Display name" Margin="0,14,0,6" Style="{StaticResource CaptionText}" />
                        <TextBox Text="{Binding RegisterDisplayName, UpdateSourceTrigger=PropertyChanged}" />
                        <TextBlock Text="Password" Margin="0,14,0,6" Style="{StaticResource CaptionText}" />
                        <PasswordBox x:Name="RegisterPasswordInput" PasswordChanged="OnRegisterPasswordChanged" Height="40" Padding="12,0" VerticalContentAlignment="Center" />
                        <TextBlock Text="Confirm password" Margin="0,14,0,6" Style="{StaticResource CaptionText}" />
                        <PasswordBox x:Name="RegisterConfirmPasswordInput" PasswordChanged="OnRegisterConfirmPasswordChanged" Height="40" Padding="12,0" VerticalContentAlignment="Center" />
                        <WrapPanel Margin="0,18,0,0">
                            <Button Content="SUBMIT SIGN UP" Command="{Binding RegisterCommand}" Style="{StaticResource PrimaryButtonStyle}" Width="170" Margin="0,0,12,10" />
                            <Button Content="CHECK STATUS" Command="{Binding CheckStatusCommand}" Style="{StaticResource CompactButtonStyle}" Width="132" Margin="0,0,12,10" />
                            <Button Content="BACK TO LOGIN" Command="{Binding ShowLoginCommand}" Style="{StaticResource CompactButtonStyle}" Width="132" Margin="0,0,0,10" />
                        </WrapPanel>
                    </StackPanel>

                    <Border Margin="0,18,0,0" Padding="16" CornerRadius="8" Background="{StaticResource BrushWarningSoft}" BorderBrush="#E7C26A" BorderThickness="1">
                        <StackPanel>
                            <DockPanel>
                                <TextBlock Text="Auth result" Foreground="{StaticResource BrushWarning}" FontWeight="SemiBold" />
                                <controls:StatusBadge DockPanel.Dock="Right" Text="{Binding AuthStatusText}" Tone="{Binding AuthStatusTone}" />
                            </DockPanel>
                            <TextBlock Text="{Binding AuthMessage}"
                                       Margin="0,8,0,0"
                                       Style="{StaticResource BodyText}"
                                       TextWrapping="Wrap" />
                        </StackPanel>
                    </Border>
                    <StackPanel Orientation="Horizontal" Margin="0,16,0,0">
                        <controls:StatusBadge Text="1. Sign up" Tone="Warning" Margin="0,0,8,0" />
                        <controls:StatusBadge Text="2. Web approval" Tone="Blue" Margin="0,0,8,0" />
                        <controls:StatusBadge Text="3. Login" Tone="Normal" />
                    </StackPanel>
                </StackPanel>
            </Border>
        </Grid>
    </StackPanel>
</UserControl>
