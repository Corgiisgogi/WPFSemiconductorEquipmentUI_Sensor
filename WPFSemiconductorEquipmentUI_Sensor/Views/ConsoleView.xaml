<UserControl x:Class="WPFSemiconductorEquipmentUI_Sensor.Views.ConsoleView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:WPFSemiconductorEquipmentUI_Sensor.Controls">
    <StackPanel>
        <DockPanel>
            <StackPanel Margin="0,0,10,0">
                <TextBlock Text="WPF Equipment Control Console" Style="{StaticResource PageTitleText}" />
                <TextBlock Text="Field control, live sensor status, and operation log." Style="{StaticResource BodyText}" />
            </StackPanel>
            <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                <controls:StatusBadge Text="RUNNING / OK" Tone="Normal" Margin="0,0,8,0" />
                <controls:StatusBadge Text="LAST UPDATE 09:24:18" Tone="Blue" Margin="0,0,8,0" />
                <controls:StatusBadge Text="AI WATCH" Tone="Warning" />
            </StackPanel>
        </DockPanel>

        <Border Margin="0,16,0,0"
                MinHeight="58"
                CornerRadius="8"
                Background="{StaticResource BrushNormalSoft}"
                BorderBrush="#A7D9C4"
                BorderThickness="1"
                Padding="16">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <controls:StatusBadge Text="NORMAL" Tone="Normal" Margin="0,0,14,0" />
                <TextBlock Text="Equipment is operating normally. Pressure and temperature are being monitored."
                           Style="{StaticResource BodyStrongText}" />
            </StackPanel>
        </Border>

        <Grid Margin="0,18,0,0" MinHeight="606">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="260" />
                <ColumnDefinition Width="18" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="18" />
                <ColumnDefinition Width="240" />
            </Grid.ColumnDefinitions>

            <Border Style="{StaticResource CardBorderStyle}">
                <StackPanel>
                    <TextBlock Text="Operator &amp; System" Style="{StaticResource SectionTitleText}" />
                    <DockPanel Margin="0,22,0,0"><TextBlock Text="User State" Style="{StaticResource BodyStrongText}" /><controls:StatusBadge DockPanel.Dock="Right" Text="APPROVED" Tone="Normal" Width="100" HorizontalAlignment="Right" /></DockPanel>
                    <DockPanel Margin="0,22,0,0"><TextBlock Text="Role" Style="{StaticResource BodyStrongText}" /><controls:StatusBadge DockPanel.Dock="Right" Text="Operator" Tone="Blue" Width="100" HorizontalAlignment="Right" /></DockPanel>
                    <DockPanel Margin="0,22,0,0"><TextBlock Text="DB" Style="{StaticResource BodyStrongText}" /><controls:StatusBadge DockPanel.Dock="Right" Text="CONNECTED" Tone="Normal" Width="100" HorizontalAlignment="Right" /></DockPanel>
                    <DockPanel Margin="0,22,0,0"><TextBlock Text="EtherCAT" Style="{StaticResource BodyStrongText}" /><controls:StatusBadge DockPanel.Dock="Right" Text="READY" Tone="Normal" Width="100" HorizontalAlignment="Right" /></DockPanel>
                    <DockPanel Margin="0,22,0,0"><TextBlock Text="Control" Style="{StaticResource BodyStrongText}" /><controls:StatusBadge DockPanel.Dock="Right" Text="ENABLED" Tone="Normal" Width="100" HorizontalAlignment="Right" /></DockPanel>
                    <Border Height="1" Margin="0,24,0,14" Background="{StaticResource BrushBorder}" />
                    <TextBlock Text="All control actions are saved to the activity log." Style="{StaticResource BodyText}" />
                </StackPanel>
            </Border>

            <Grid Grid.Column="2">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="18" />
                    <RowDefinition Height="282" />
                </Grid.RowDefinitions>
                <ItemsControl ItemsSource="{Binding Sensors}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <controls:SensorCard Title="{Binding Name}"
                                                 Value="{Binding Value}"
                                                 Unit="{Binding Unit}"
                                                 RangeText="{Binding RangeText}"
                                                 BadgeText="{Binding BadgeText}"
                                                 Tone="{Binding Tone}"
                                                 IndicatorWidth="{Binding IndicatorWidth}"
                                                 Margin="0,0,14,14" />
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <Border Grid.Row="2" Style="{StaticResource CardBorderStyle}" Padding="0">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="50" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>
                        <DockPanel Margin="10,0">
                            <TextBlock Text="Activity Log" Style="{StaticResource SectionTitleText}" VerticalAlignment="Center" />
                            <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" VerticalAlignment="Center" Margin="8">
                                <controls:StatusBadge Text="ALL" Tone="Blue" Margin="0,0,8,0" />
                                <controls:StatusBadge Text="WARN" Tone="Warning" Margin="0,0,8,0" />
                                <controls:StatusBadge Text="RISK" Tone="Danger" />
                            </StackPanel>
                        </DockPanel>
                        <DataGrid Grid.Row="1" ItemsSource="{Binding ActivityLogs}" BorderThickness="0">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Time" Binding="{Binding Time}" Width="80" />
                                <DataGridTextColumn Header="Event" Binding="{Binding Event}" Width="*" />
                                <DataGridTextColumn Header="User" Binding="{Binding User}" Width="120" />
                                <DataGridTextColumn Header="Level" Binding="{Binding Severity}" Width="90" />
                            </DataGrid.Columns>
                        </DataGrid>
                    </Grid>
                </Border>
            </Grid>

            <Border Grid.Column="4" Style="{StaticResource CardBorderStyle}">
                <StackPanel>
                    <TextBlock Text="Equipment Control" Style="{StaticResource SectionTitleText}" />
                    <Button Content="START" Style="{StaticResource PrimaryButtonStyle}" Margin="0,18,0,0" />
                    <Button Content="STOP" Style="{StaticResource SecondaryButtonStyle}" Margin="0,12,0,0" />
                    <Button Content="LOCKED" Style="{StaticResource DisabledButtonStyle}" Margin="0,12,0,0" />
                    <Border Margin="0,16,0,0" Padding="14" CornerRadius="8" Background="{StaticResource BrushDangerSoft}" BorderBrush="#F2B8B5" BorderThickness="1">
                        <StackPanel>
                            <TextBlock Text="Emergency" Foreground="{StaticResource BrushDanger}" FontWeight="SemiBold" />
                            <Button Content="FORCE SHUTDOWN" Style="{StaticResource DangerButtonStyle}" Margin="0,10,0,0" />
                            <TextBlock Text="Runs only for admin command or AI risk condition."
                                       Margin="0,8,0,0"
                                       Style="{StaticResource CaptionText}" />
                        </StackPanel>
                    </Border>
                    <Border Height="1" Margin="0,16,0,14" Background="{StaticResource BrushBorder}" />
                    <TextBlock Text="AI Risk Rule: Detect / Warn / Stop" Style="{StaticResource BodyStrongText}" />
                    <Border Margin="0,14,0,0" Height="92" CornerRadius="6" Background="{StaticResource BrushSurfaceSubtle}" Padding="12">
                        <StackPanel>
                            <TextBlock Text="Sensor Trend" Style="{StaticResource CaptionText}" FontWeight="SemiBold" />
                            <Rectangle Height="2" Margin="0,8,0,0" Fill="{StaticResource BrushWarning}" />
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Border>
        </Grid>
    </StackPanel>
</UserControl>
