<UserControl x:Class="WPFSemiconductorEquipmentUI_Sensor.Views.ConsoleView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:WPFSemiconductorEquipmentUI_Sensor.Controls">
    <Grid Background="#F3F4F6">
        <Grid.RowDefinitions>
            <RowDefinition Height="42" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="#FFF7D6" BorderBrush="#F59E0B" BorderThickness="1" Padding="14,0">
            <DockPanel VerticalAlignment="Center">
                <TextBlock Text="⚠" FontSize="18" Foreground="#D97706" Margin="0,0,12,0" VerticalAlignment="Center" />
                <controls:StatusBadge Text="{Binding RiskStatusText}" Tone="{Binding RiskStatusTone}" Width="92" Margin="0,0,14,0" />
                <TextBlock Text="{Binding RiskDetailText}" Margin="0,0,12,0" VerticalAlignment="Center" FontSize="14" FontWeight="SemiBold" Foreground="#5B3B00" TextWrapping="NoWrap" TextTrimming="CharacterEllipsis" />
                <TextBlock DockPanel.Dock="Right" Text="{Binding SummaryBadgeText}" VerticalAlignment="Center" FontSize="14" FontWeight="Bold" Foreground="#1F2937" />
            </DockPanel>
        </Border>

        <Grid Grid.Row="1" Margin="0,10,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="350" />
                <ColumnDefinition Width="10" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="10" />
                <ColumnDefinition Width="390" />
            </Grid.ColumnDefinitions>

            <!-- LEFT: Command and I/O -->
            <Border Grid.Column="0" Background="#F8FAFC" BorderBrush="#B8C0CC" BorderThickness="1" Padding="14">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="160" />
                        <RowDefinition Height="8" />
                        <RowDefinition Height="200" />
                        <RowDefinition Height="8" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <TextBlock Text="명령 / 수동 제어" FontSize="18" FontWeight="Bold" Foreground="#111827" />
                    <UniformGrid Grid.Row="1" Columns="2" Rows="3" Margin="0,10,0,0">
                        <Button Content="공정 시작" Command="{Binding ProcessStartCommand}" Style="{StaticResource PrimaryButtonStyle}" Margin="0,0,8,8" />
                        <Button Content="공정 정지" Command="{Binding ProcessStopCommand}" Style="{StaticResource DangerButtonStyle}" Margin="0,0,0,8" />
                        <Button Content="AI 시작" Command="{Binding AiControlStartCommand}" Style="{StaticResource CompactButtonStyle}" Margin="0,0,8,8" />
                        <Button Content="AI 정지" Command="{Binding AiControlStopCommand}" Style="{StaticResource CompactButtonStyle}" Margin="0,0,0,8" />
                        <Button Content="강제 정지" Command="{Binding ForceShutdownCommand}" Style="{StaticResource DangerButtonStyle}" Margin="0,0,8,0" />
                        <controls:StatusBadge Text="{Binding ForceShutdownAccessText}" Tone="{Binding ForceShutdownAccessTone}" Margin="0,0,0,0" />
                    </UniformGrid>

                    <Border Grid.Row="3" BorderBrush="#D1D5DB" BorderThickness="0,1,0,1" Padding="0,10">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="84" />
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="25" />
                                <RowDefinition Height="25" />
                                <RowDefinition Height="25" />
                                <RowDefinition Height="25" />
                                <RowDefinition Height="25" />
                                <RowDefinition Height="25" />
                                <RowDefinition Height="25" />
                            </Grid.RowDefinitions>
                            <TextBlock Text="디지털 입력 (DI)" FontWeight="Bold" Foreground="#111827" />
                            <TextBlock Grid.Column="1" Text="상태" FontWeight="Bold" HorizontalAlignment="Center" />
                            <TextBlock Grid.Row="1" Text="DI1  공정 시작" VerticalAlignment="Center" />
                            <controls:StatusBadge Grid.Row="1" Grid.Column="1" Text="{Binding DigitalInput1Text}" Tone="{Binding DigitalInput1Tone}" Width="62" Margin="2"/>
                            <TextBlock Grid.Row="2" Text="DI2  공정 정지" VerticalAlignment="Center" />
                            <controls:StatusBadge Grid.Row="2" Grid.Column="1" Text="{Binding DigitalInput2Text}" Tone="{Binding DigitalInput2Tone}" Width="62" Margin="2"/>
                            <TextBlock Grid.Row="3" Text="DI3  AI 시작" VerticalAlignment="Center" />
                            <controls:StatusBadge Grid.Row="3" Grid.Column="1" Text="{Binding DigitalInput3Text}" Tone="{Binding DigitalInput3Tone}" Width="62" Margin="2"/>
                            <TextBlock Grid.Row="4" Text="DI4  AI 정지" VerticalAlignment="Center" />
                            <controls:StatusBadge Grid.Row="4" Grid.Column="1" Text="{Binding DigitalInput4Text}" Tone="{Binding DigitalInput4Tone}" Width="62" Margin="2"/>
                            <TextBlock Grid.Row="5" Text="DI5  광센서 / FOUP A" VerticalAlignment="Center" />
                            <controls:StatusBadge Grid.Row="5" Grid.Column="1" Text="{Binding OpticalSensorText}" Tone="{Binding OpticalSensorTone}" Width="62" Margin="2"/>
                            <TextBlock Grid.Row="6" Text="DI6  근접센서 / FOUP B" VerticalAlignment="Center" />
                            <controls:StatusBadge Grid.Row="6" Grid.Column="1" Text="{Binding InductiveSensorText}" Tone="{Binding InductiveSensorTone}" Width="62" Margin="2"/>
                        </Grid>
                    </Border>

                    <StackPanel Grid.Row="5">
                        <TextBlock Text="디지털 출력 (DO)" FontSize="15" FontWeight="Bold" Foreground="#111827" />
                        <Grid Margin="0,10,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="84" />
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="24" />
                                <RowDefinition Height="24" />
                                <RowDefinition Height="24" />
                            </Grid.RowDefinitions>
                            <TextBlock Text="DO2  공정 램프" VerticalAlignment="Center" />
                            <controls:StatusBadge Grid.Column="1" Text="{Binding Do2LampText}" Tone="{Binding Do2LampTone}" Width="62" Margin="2"/>
                            <TextBlock Grid.Row="1" Text="DO3  경고/위험 램프" VerticalAlignment="Center" />
                            <controls:StatusBadge Grid.Row="1" Grid.Column="1" Text="{Binding Do3LampText}" Tone="{Binding Do3LampTone}" Width="62" Margin="2"/>
                            <TextBlock Grid.Row="2" Text="DO4  AI 제어 램프" VerticalAlignment="Center" />
                            <controls:StatusBadge Grid.Row="2" Grid.Column="1" Text="{Binding Do4LampText}" Tone="{Binding Do4LampTone}" Width="62" Margin="2"/>
                        </Grid>
                        <Border Margin="0,10,0,0" Height="48" CornerRadius="4" BorderBrush="#86D1A8" BorderThickness="1" Background="#ECFDF5">
                            <DockPanel Margin="12,0">
                                <TextBlock Text="인터락 상태" FontWeight="Bold" VerticalAlignment="Center" />
                                <controls:StatusBadge DockPanel.Dock="Right" Text="{Binding FoupReadyText}" Tone="{Binding FoupReadyTone}" Width="92" />
                            </DockPanel>
                        </Border>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- CENTER: Equipment overview -->
            <Border Grid.Column="2" Background="#F8FAFC" BorderBrush="#B8C0CC" BorderThickness="1" Padding="12">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="34" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="28" />
                    </Grid.RowDefinitions>
                    <DockPanel>
                        <TextBlock Text="장비 개요 (EQUIPMENT OVERVIEW)" FontSize="18" FontWeight="Bold" Foreground="#111827" Padding="0,0,10,0"/>
                        <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                            <controls:StatusBadge Text="{Binding EquipmentStateText}" Tone="{Binding EquipmentStateTone}" Width="102" Margin="0,0,8,0" />
                            <controls:StatusBadge Text="{Binding ProcessRunStateText}" Tone="{Binding ProcessRunStateTone}" Width="86" />
                        </StackPanel>
                    </DockPanel>

                    <Viewbox Grid.Row="1" Stretch="Uniform">
                        <Canvas Width="680" Height="430" Background="#F8FAFC">
                            <!-- Network boxes -->
                            <Border Canvas.Left="210" Canvas.Top="22" Width="130" Height="70" BorderBrush="#9CA3AF" BorderThickness="1" Background="#F9FAFB" Padding="8">
                                <StackPanel>
                                    <DockPanel><TextBlock Text="PLC / ADS" FontWeight="Bold" /><controls:StatusBadge DockPanel.Dock="Right" Text="OK" Tone="Normal" Width="42" /></DockPanel>
                                    <TextBlock Text="TwinCAT ADS" Margin="0,10,0,0" FontSize="12" />
                                </StackPanel>
                            </Border>
                            <Border Canvas.Left="390" Canvas.Top="22" Width="150" Height="70" BorderBrush="#9CA3AF" BorderThickness="1" Background="#F9FAFB" Padding="8">
                                <StackPanel>
                                    <DockPanel><TextBlock Text="EtherCAT" FontWeight="Bold" /><controls:StatusBadge DockPanel.Dock="Right" Text="OP" Tone="Normal" Width="42" /></DockPanel>
                                    <TextBlock Text="Cycle 1.0 ms" Margin="0,10,0,0" FontSize="12" />
                                </StackPanel>
                            </Border>
                            <Line X1="275" Y1="92" X2="275" Y2="140" Stroke="#22C55E" StrokeThickness="2" />
                            <Line X1="465" Y1="92" X2="465" Y2="140" Stroke="#22C55E" StrokeThickness="2" />
                            <Line X1="100" Y1="140" X2="610" Y2="140" Stroke="#111827" StrokeThickness="2" />

                            <!-- Modules -->
                            <Border Canvas.Left="34" Canvas.Top="170" Width="132" Height="150" BorderBrush="#9CA3AF" BorderThickness="1" Background="#F9FAFB" Padding="8">
                                <StackPanel>
                                    <DockPanel>
                                        <controls:StatusBadge Text="" Tone="{Binding FoupAStateTone}" Width="20" Margin="0,0,4,0" />
                                        <TextBlock Text="LOAD PORT A" FontWeight="Bold" FontSize="12" />
                                    </DockPanel>
                                    <TextBlock Text="FOUP A" Margin="0,12,0,0" />
                                    <controls:StatusBadge Text="{Binding FoupAStateText}" Tone="{Binding FoupAStateTone}" Width="72" Margin="0,8,0,0" />
                                </StackPanel>
                            </Border>
                            <Border Canvas.Left="514" Canvas.Top="170" Width="132" Height="150" BorderBrush="#9CA3AF" BorderThickness="1" Background="#F9FAFB" Padding="8">
                                <StackPanel>
                                    <DockPanel>
                                        <controls:StatusBadge Text="" Tone="{Binding FoupBStateTone}" Width="20" Margin="0,0,4,0" />
                                        <TextBlock Text="LOAD PORT B" FontWeight="Bold" FontSize="12" />
                                    </DockPanel>
                                    <TextBlock Text="FOUP B" Margin="0,12,0,0" />
                                    <controls:StatusBadge Text="{Binding FoupBStateText}" Tone="{Binding FoupBStateTone}" Width="72" Margin="0,8,0,0" />
                                </StackPanel>
                            </Border>

                            <!-- Chamber schematic -->
                            <Ellipse Canvas.Left="290" Canvas.Top="214" Width="110" Height="110" Fill="#E5E7EB" Stroke="#111827" StrokeThickness="1.5" />
                            <Rectangle Canvas.Left="235" Canvas.Top="255" Width="220" Height="42" Fill="#CBD5E1" Stroke="#111827" StrokeThickness="1.5" />
                            <Line X1="166" Y1="218" X2="235" Y2="275" Stroke="#9CA3AF" StrokeThickness="2" />
                            <Line X1="455" Y1="275" X2="514" Y2="218" Stroke="#9CA3AF" StrokeThickness="2" />
                            <Border Canvas.Left="280" Canvas.Top="344" Width="130" Height="74" CornerRadius="36" BorderBrush="#9CA3AF" BorderThickness="1" Background="#F9FAFB" Padding="10">
                                <StackPanel HorizontalAlignment="Center">
                                    <TextBlock Text="챔버" FontWeight="Bold" HorizontalAlignment="Center" />
                                    <TextBlock Text="{Binding ProcessRunStateText}" Margin="0,6,0,0" HorizontalAlignment="Center" />
                                    <TextBlock Text="{Binding PressureDisplayText}" FontSize="12" HorizontalAlignment="Center" />
                                    <TextBlock Text="{Binding TemperatureDisplayText}" FontSize="12" HorizontalAlignment="Center" />
                                </StackPanel>
                            </Border>

                            <!-- Sensor module and lamp -->
                            <Border Canvas.Left="570" Canvas.Top="42" Width="92" Height="90" BorderBrush="#9CA3AF" BorderThickness="1" Background="#F9FAFB" Padding="8">
                                <StackPanel>
                                    <TextBlock Text="센서 모듈" FontWeight="Bold" />
                                    <controls:StatusBadge Text="{Binding RiskStatusText}" Tone="{Binding RiskStatusTone}" Width="72" Margin="0,10,0,0" />
                                </StackPanel>
                            </Border>
                            <Border Canvas.Left="270" Canvas.Top="160" Width="150" Height="48" BorderBrush="#6B7280" BorderThickness="1" Background="#F9FAFB">
                                <StackPanel Orientation="Horizontal">
                                    <controls:StatusBadge Text="DO3" Tone="{Binding Do3LampTone}" Height="38" />
                                    <controls:StatusBadge Text="DO4" Tone="{Binding Do4LampTone}" Height="38" />
                                    <controls:StatusBadge Text="DO2" Tone="{Binding Do2LampTone}" Height="38" />
                                </StackPanel>
                            </Border>

                        </Canvas>
                    </Viewbox>
                    <TextBlock Grid.Row="2"
                               Text="* FOUP A/B 감지 + 승인 사용자 조건에서 공정 시작 가능"
                               FontSize="12"
                               Foreground="#2563EB"
                               VerticalAlignment="Center"
                               TextWrapping="Wrap"
                               TextTrimming="CharacterEllipsis" />
                </Grid>
            </Border>

            <!-- RIGHT: selected module details -->
            <Border Grid.Column="4" Background="#F8FAFC" BorderBrush="#B8C0CC" BorderThickness="1" Padding="12">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="240" />
                        <RowDefinition Height="10" />
                        <RowDefinition Height="112" />
                        <RowDefinition Height="10" />
                        <RowDefinition Height="138" />
                    </Grid.RowDefinitions>
                    <TextBlock Text="선택된 모듈 상세" FontSize="18" FontWeight="Bold" Foreground="#111827" />
                    <Border Grid.Row="1" Margin="0,12,0,0" BorderBrush="#D1D5DB" BorderThickness="1" Background="#F9FAFB">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="36" />
                                <RowDefinition Height="36" />
                                <RowDefinition Height="36" />
                                <RowDefinition Height="36" />
                                <RowDefinition Height="36" />
                                <RowDefinition Height="36" />
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="98" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="70" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="항목" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center" />
                            <TextBlock Grid.Column="1" Text="값" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center" />
                            <TextBlock Grid.Column="2" Text="상태" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center" />
                            <TextBlock Grid.Row="1" Text="압력" Margin="12,0" VerticalAlignment="Center" />
                            <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding PressureDisplayText}" HorizontalAlignment="Center" VerticalAlignment="Center" />
                            <controls:StatusBadge Grid.Row="1" Grid.Column="2" Text="{Binding PressureStatusText}" Tone="{Binding PressureStatusTone}" Width="58" Margin="2"/>
                            <TextBlock Grid.Row="2" Text="온도" Margin="12,0" VerticalAlignment="Center" />
                            <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding TemperatureDisplayText}" HorizontalAlignment="Center" VerticalAlignment="Center" />
                            <controls:StatusBadge Grid.Row="2" Grid.Column="2" Text="{Binding TemperatureStatusText}" Tone="{Binding TemperatureStatusTone}" Width="58" Margin="2"/>
                            <TextBlock Grid.Row="3" Text="진동" Margin="12,0" VerticalAlignment="Center" />
                            <TextBlock Grid.Row="3" Grid.Column="1" Text="{Binding VibrationDisplayText}" HorizontalAlignment="Center" VerticalAlignment="Center" />
                            <controls:StatusBadge Grid.Row="3" Grid.Column="2" Text="{Binding VibrationStatusText}" Tone="{Binding VibrationStatusTone}" Width="58" Margin="2"/>
                            <TextBlock Grid.Row="4" Text="습도" Margin="12,0" VerticalAlignment="Center" />
                            <TextBlock Grid.Row="4" Grid.Column="1" Text="{Binding HumidityDisplayText}" HorizontalAlignment="Center" VerticalAlignment="Center" />
                            <controls:StatusBadge Grid.Row="4" Grid.Column="2" Text="{Binding HumidityStatusText}" Tone="{Binding HumidityStatusTone}" Width="58" Margin="2"/>
                            <TextBlock Grid.Row="5" Text="상태" Margin="12,0" VerticalAlignment="Center" />
                            <controls:StatusBadge Grid.Row="5" Grid.Column="1" Grid.ColumnSpan="2" Text="{Binding EquipmentStateText}" Tone="{Binding EquipmentStateTone}" Width="98" HorizontalAlignment="Right" Margin="0,2,12,0"/>
                        </Grid>
                    </Border>

                    <Border Grid.Row="3" BorderBrush="#D1D5DB" BorderThickness="1" Background="#F9FAFB" Padding="12">
                        <StackPanel>
                            <DockPanel>
                                <TextBlock Text="AI CONTROL" FontWeight="Bold" FontSize="16" />
                                <controls:StatusBadge DockPanel.Dock="Right" Text="{Binding AiRunStateText}" Tone="{Binding AiRunStateTone}" Width="82" />
                            </DockPanel>
                            <TextBlock Text="{Binding AiRunDetailText}" Margin="0,10,0,0" TextWrapping="Wrap" />
                        </StackPanel>
                    </Border>

                    <Border Grid.Row="5" BorderBrush="#D1D5DB" BorderThickness="1" Background="#F9FAFB" Padding="10">
                        <StackPanel>
                            <DockPanel>
                                <TextBlock Text="ALARM" FontWeight="Bold" FontSize="16" />
                                <controls:StatusBadge DockPanel.Dock="Right" Text="{Binding RiskStatusText}" Tone="{Binding RiskStatusTone}" Width="88" />
                            </DockPanel>
                            <TextBlock Text="{Binding RiskDetailText}" Margin="0,8,0,0" TextWrapping="Wrap" TextTrimming="CharacterEllipsis" MaxHeight="36" />
                            <Border Height="1" Margin="0,8,0,8" Background="#D1D5DB" />
                            <TextBlock Text="MODULE INFO" FontWeight="Bold" />
                            <TextBlock Text="{Binding FoupReadyDetailText}" Margin="0,6,0,0" TextWrapping="Wrap" TextTrimming="CharacterEllipsis" MaxHeight="34" />
                        </StackPanel>
                    </Border>
                </Grid>
            </Border>
        </Grid>

    </Grid>
</UserControl>
