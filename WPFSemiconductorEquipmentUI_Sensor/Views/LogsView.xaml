<UserControl x:Class="WPFSemiconductorEquipmentUI_Sensor.Views.LogsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:WPFSemiconductorEquipmentUI_Sensor.Controls">
    <StackPanel>
        <DockPanel>
            <StackPanel Margin="0,0,10,0">
                <TextBlock Text="Activity &amp; Sensor Logs" Style="{StaticResource PageTitleText}" />
                <TextBlock Text="Review saved activity events and sensor records." Style="{StaticResource BodyText}" />
            </StackPanel>
            <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                <controls:StatusBadge Text="SQLite SYNC" Tone="Normal" Margin="0,0,8,0" />
                <controls:StatusBadge Text="AUDIT TRAIL" Tone="Blue" Margin="0,0,8,0" />
                <controls:StatusBadge Text="FILTERED VIEW" Tone="Blue" />
            </StackPanel>
        </DockPanel>

        <Border Margin="0,16,0,0" Style="{StaticResource CardBorderStyle}" Padding="14">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="114" />
                    <ColumnDefinition Width="114" />
                    <ColumnDefinition Width="120" />
                    <ColumnDefinition Width="126" />
                    <ColumnDefinition Width="112" />
                    <ColumnDefinition Width="*" MinWidth="150" />
                    <ColumnDefinition Width="104" />
                </Grid.ColumnDefinitions>

                <StackPanel Margin="0,0,10,0">
                    <TextBlock Text="From" Style="{StaticResource CaptionText}" />
                    <TextBox Text="2026-05-28" />
                </StackPanel>
                <StackPanel Grid.Column="1" Margin="0,0,10,0">
                    <TextBlock Text="To" Style="{StaticResource CaptionText}" />
                    <TextBox Text="2026-05-28" />
                </StackPanel>
                <StackPanel Grid.Column="2" Margin="0,0,10,0">
                    <TextBlock Text="User" Style="{StaticResource CaptionText}" />
                    <ComboBox SelectedIndex="0">
                        <ComboBoxItem Content="All users" />
                    </ComboBox>
                </StackPanel>
                <StackPanel Grid.Column="3" Margin="0,0,10,0">
                    <TextBlock Text="Type" Style="{StaticResource CaptionText}" />
                    <ComboBox SelectedIndex="0">
                        <ComboBoxItem Content="All events" />
                    </ComboBox>
                </StackPanel>
                <StackPanel Grid.Column="4" Margin="0,0,10,0">
                    <TextBlock Text="Severity" Style="{StaticResource CaptionText}" />
                    <ComboBox SelectedIndex="0">
                        <ComboBoxItem Content="All" />
                    </ComboBox>
                </StackPanel>
                <StackPanel Grid.Column="5" Margin="0,0,10,0">
                    <TextBlock Text="Search" Style="{StaticResource CaptionText}" />
                    <TextBox Text="pressure, shutdown..." />
                </StackPanel>
                <Button Grid.Column="6"
                        Content="EXPORT"
                        Style="{StaticResource CompactButtonStyle}"
                        Width="104"
                        VerticalAlignment="Bottom" />
            </Grid>
        </Border>

        <UniformGrid Columns="4" Margin="0,16,0,0">
            <Border Style="{StaticResource CardBorderStyle}" MinHeight="124" Padding="16" Margin="0,0,12,0">
                <StackPanel>
                    <controls:StatusBadge Text="TOTAL LOGS" Tone="Blue" HorizontalAlignment="Left" />
                    <TextBlock Text="1,248" Margin="0,10,0,0" FontSize="28" FontWeight="Bold" Foreground="{StaticResource BrushTextPrimary}" />
                    <TextBlock Text="Today / SQLite records" Style="{StaticResource CaptionText}" TextWrapping="Wrap" />
                </StackPanel>
            </Border>
            <Border Style="{StaticResource CardBorderStyle}" MinHeight="124" Padding="16" Margin="0,0,12,0">
                <StackPanel>
                    <controls:StatusBadge Text="WARNINGS" Tone="Warning" HorizontalAlignment="Left" />
                    <TextBlock Text="14" Margin="0,10,0,0" FontSize="28" FontWeight="Bold" Foreground="{StaticResource BrushTextPrimary}" />
                    <TextBlock Text="AI watch and sensor threshold" Style="{StaticResource CaptionText}" TextWrapping="Wrap" />
                </StackPanel>
            </Border>
            <Border Style="{StaticResource CardBorderStyle}" MinHeight="124" Padding="16" Margin="0,0,12,0">
                <StackPanel>
                    <controls:StatusBadge Text="RISK EVENTS" Tone="Danger" HorizontalAlignment="Left" />
                    <TextBlock Text="2" Margin="0,10,0,0" FontSize="28" FontWeight="Bold" Foreground="{StaticResource BrushTextPrimary}" />
                    <TextBlock Text="Shutdown-related events" Style="{StaticResource CaptionText}" TextWrapping="Wrap" />
                </StackPanel>
            </Border>
            <Border Style="{StaticResource CardBorderStyle}" MinHeight="124" Padding="16">
                <StackPanel>
                    <controls:StatusBadge Text="LAST SHUTDOWN" Tone="Normal" HorizontalAlignment="Left" />
                    <TextBlock Text="09:28" Margin="0,10,0,0" FontSize="28" FontWeight="Bold" Foreground="{StaticResource BrushTextPrimary}" />
                    <TextBlock Text="Command saved successfully" Style="{StaticResource CaptionText}" TextWrapping="Wrap" />
                </StackPanel>
            </Border>
        </UniformGrid>

        <Grid Margin="0,18,0,0" MinHeight="472">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" MinWidth="600" />
                <ColumnDefinition Width="16" />
                <ColumnDefinition Width="276" />
            </Grid.ColumnDefinitions>

            <DataGrid ItemsSource="{Binding ActivityLogs}" SelectedItem="{Binding SelectedLog}" AlternationCount="2">
                <DataGrid.Resources>
                    <Style x:Key="LogCellTextStyle" TargetType="TextBlock">
                        <Setter Property="TextTrimming" Value="CharacterEllipsis" />
                        <Setter Property="VerticalAlignment" Value="Center" />
                    </Style>
                </DataGrid.Resources>
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Time" Binding="{Binding Time}" Width="72" ElementStyle="{StaticResource LogCellTextStyle}" />
                    <DataGridTextColumn Header="Source" Binding="{Binding Source}" Width="76" ElementStyle="{StaticResource LogCellTextStyle}" />
                    <DataGridTextColumn Header="User" Binding="{Binding User}" Width="78" ElementStyle="{StaticResource LogCellTextStyle}" />
                    <DataGridTextColumn Header="Event" Binding="{Binding Event}" Width="*" ElementStyle="{StaticResource LogCellTextStyle}" />
                    <DataGridTextColumn Header="Severity" Binding="{Binding Severity}" Width="72" ElementStyle="{StaticResource LogCellTextStyle}" />
                    <DataGridTextColumn Header="Saved" Binding="{Binding Saved}" Width="58" ElementStyle="{StaticResource LogCellTextStyle}" />
                </DataGrid.Columns>
            </DataGrid>

            <Border Grid.Column="2" Style="{StaticResource CardBorderStyle}">
                <StackPanel>
                    <TextBlock Text="Selected Log Detail" Style="{StaticResource SectionTitleText}" />
                    <controls:StatusBadge Text="EVENT EVT-092802" Tone="Blue" HorizontalAlignment="Left" Margin="0,14,0,0" />
                    <TextBlock Text="Remote shutdown command received from admin."
                               Margin="0,14,0,0"
                               Style="{StaticResource BodyText}"
                               TextWrapping="Wrap" />
                    <Border Margin="0,16,0,0" Padding="12" CornerRadius="8" Background="{StaticResource BrushSurfaceSubtle}">
                        <StackPanel>
                            <TextBlock Text="Sensor Snapshot" Style="{StaticResource BodyStrongText}" />
                            <DockPanel Margin="0,12,0,0"><TextBlock Text="Pressure" Style="{StaticResource CaptionText}" /><controls:StatusBadge DockPanel.Dock="Right" Text="3.1 bar" Tone="Warning" /></DockPanel>
                            <DockPanel Margin="0,10,0,0"><TextBlock Text="Vibration" Style="{StaticResource CaptionText}" /><controls:StatusBadge DockPanel.Dock="Right" Text="0.12 g" Tone="Normal" /></DockPanel>
                            <DockPanel Margin="0,10,0,0"><TextBlock Text="Temperature" Style="{StaticResource CaptionText}" /><controls:StatusBadge DockPanel.Dock="Right" Text="42 C" Tone="Warning" /></DockPanel>
                            <DockPanel Margin="0,10,0,0"><TextBlock Text="Humidity" Style="{StaticResource CaptionText}" /><controls:StatusBadge DockPanel.Dock="Right" Text="41 %" Tone="Normal" /></DockPanel>
                        </StackPanel>
                    </Border>
                    <TextBlock Text="Source: Flask Admin Dashboard" Margin="0,14,0,0" Style="{StaticResource CaptionText}" TextWrapping="Wrap" />
                    <TextBlock Text="Actor: admin" Margin="0,8,0,0" Style="{StaticResource CaptionText}" />
                    <TextBlock Text="Command: FORCE_SHUTDOWN" Margin="0,8,0,0" Style="{StaticResource CaptionText}" />
                    <TextBlock Text="Saved: SQLite / activity_log" Margin="0,8,0,0" Style="{StaticResource CaptionText}" TextWrapping="Wrap" />
                </StackPanel>
            </Border>
        </Grid>
    </StackPanel>
</UserControl>
