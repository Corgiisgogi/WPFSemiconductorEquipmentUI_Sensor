<UserControl x:Class="WPFSemiconductorEquipmentUI_Sensor.Views.SettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:WPFSemiconductorEquipmentUI_Sensor.Controls">
    <UserControl.Resources>
        <Style TargetType="TextBox" BasedOn="{StaticResource {x:Type TextBox}}">
            <Setter Property="Height" Value="34" />
        </Style>
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
        <StackPanel>
            <DockPanel>
                <StackPanel Margin="0,0,10,0">
                    <TextBlock Text="시스템 설정" Style="{StaticResource PageTitleText}" />
                    <TextBlock Text="연결, 인증, 위험 규칙, 저장 정책을 설정합니다." Style="{StaticResource BodyText}" />
                </StackPanel>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                    <controls:StatusBadge Text="관리자 전용" Tone="Danger" Margin="0,0,8,0" />
                    <controls:StatusBadge Text="안전 기본값" Tone="Normal" Margin="0,0,8,0" />
                    <controls:StatusBadge Text="{Binding SettingsStatusText}" Tone="{Binding SettingsStatusTone}" />
                </StackPanel>
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" HorizontalAlignment="Right">
                    <Border Style="{StaticResource CardBorderStyle}" Padding="12" Margin="10,10,0,0">
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                            <Button Content="저장" Command="{Binding SaveCommand}" Style="{StaticResource PrimaryButtonStyle}" Width="132" MinWidth="0" />
                            <Button Content="초기화" Command="{Binding ResetCommand}" Style="{StaticResource CompactButtonStyle}" Width="112" Margin="10,0,0,0" />
                            <Button Content="테스트" Command="{Binding TestCommand}" Style="{StaticResource CompactButtonStyle}" Width="112" Margin="10,0,0,0" />
                        </StackPanel>
                    </Border>
                </StackPanel>
            </DockPanel>

            <Border Margin="0,16,0,0"
                CornerRadius="8"
                Background="{StaticResource BrushWarningSoft}"
                BorderBrush="#E7C26A"
                BorderThickness="1"
                Padding="16">
            <DockPanel>
                <controls:StatusBadge Text="주의" Tone="Warning" Margin="0,0,14,0" />
                <TextBlock Text="저장 전 위험 임계값과 정지 정책을 확인하세요."
                           Style="{StaticResource BodyStrongText}"
                           TextWrapping="Wrap" />
            </DockPanel>
        </Border>

        <Grid Margin="0,16,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="18" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <StackPanel>
                <Border Style="{StaticResource CardBorderStyle}" Padding="12">
                    <StackPanel>
                        <DockPanel LastChildFill="False">
                            <TextBlock Text="연결 설정" Style="{StaticResource SectionTitleText}" />
                            <controls:StatusBadge DockPanel.Dock="Right" Text="온라인" Tone="Normal" />
                        </DockPanel>

                        <Grid Margin="0,12,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="190" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="EtherCAT 연결" Style="{StaticResource BodyStrongText}" VerticalAlignment="Center" />
                            <controls:StatusBadge Grid.Column="1" Text="준비" Tone="Normal" HorizontalAlignment="Right" />
                        </Grid>
                        <Grid Margin="0,8,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="190" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="장비 ID" Style="{StaticResource BodyStrongText}" VerticalAlignment="Center" />
                            <TextBox Grid.Column="1" Text="EQP-TRAINER-01" />
                        </Grid>
                        <Grid Margin="0,8,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="190" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="SQLite DB 경로" Style="{StaticResource BodyStrongText}" VerticalAlignment="Center" />
                            <TextBox Grid.Column="1" Text="{Binding DatabasePath, Mode=OneWay}" IsReadOnly="True" />
                        </Grid>
                        <Grid Margin="0,8,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="190" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Flask API URL" Style="{StaticResource BodyStrongText}" VerticalAlignment="Center" />
                            <TextBox Grid.Column="1" Text="{Binding ApiBaseUrl, UpdateSourceTrigger=PropertyChanged}" />
                        </Grid>
                        <Grid Margin="0,8,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="190" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="센서 저장 간격" Style="{StaticResource BodyStrongText}" VerticalAlignment="Center" />
                            <TextBox Grid.Column="1" Text="{Binding SensorSnapshotSaveIntervalSeconds, UpdateSourceTrigger=PropertyChanged}" />
                        </Grid>
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource CardBorderStyle}" Padding="12" Margin="0,10,0,0">
                    <StackPanel>
                        <DockPanel LastChildFill="False">
                            <TextBlock Text="인증 설정" Style="{StaticResource SectionTitleText}" />
                            <controls:StatusBadge DockPanel.Dock="Right" Text="승인 필요" Tone="Warning" />
                        </DockPanel>

                        <Grid Margin="0,12,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="64" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="승인 사용자만 허용" Style="{StaticResource BodyStrongText}" VerticalAlignment="Center" />
                            <ToggleButton Grid.Column="1" Style="{StaticResource SwitchToggleStyle}" IsChecked="True" HorizontalAlignment="Right" />
                        </Grid>
                        <Grid Margin="0,8,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="64" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="승인 대기 계정 차단" Style="{StaticResource BodyStrongText}" VerticalAlignment="Center" />
                            <ToggleButton Grid.Column="1" Style="{StaticResource SwitchToggleStyle}" IsChecked="True" HorizontalAlignment="Right" />
                        </Grid>
                        <Grid Margin="0,8,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="190" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="세션 만료" Style="{StaticResource BodyStrongText}" VerticalAlignment="Center" />
                            <TextBox Grid.Column="1" Text="15분" />
                        </Grid>
                        <Grid Margin="0,8,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="190" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="제어 권한" Style="{StaticResource BodyStrongText}" VerticalAlignment="Center" />
                            <TextBox Grid.Column="1" Text="작업자 1단계" />
                        </Grid>
                    </StackPanel>
                </Border>
            </StackPanel>

            <StackPanel Grid.Column="2">
                <Border Style="{StaticResource CardBorderStyle}" Padding="12">
                    <StackPanel>
                        <DockPanel LastChildFill="False">
                            <TextBlock Text="AI 위험 규칙" Style="{StaticResource SectionTitleText}" />
                            <controls:StatusBadge DockPanel.Dock="Right" Text="감시 중" Tone="Warning" />
                        </DockPanel>

                        <Grid Margin="0,12,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="190" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="압력 경고 기준 (0~0.45 bar)" Style="{StaticResource BodyStrongText}" VerticalAlignment="Center" />
                            <TextBox Grid.Column="1" Text="{Binding PressureWarningThresholdText, UpdateSourceTrigger=PropertyChanged}" />
                        </Grid>
                        <Grid Margin="0,8,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="190" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="온도 경고 기준" Style="{StaticResource BodyStrongText}" VerticalAlignment="Center" />
                            <TextBox Grid.Column="1" Text="{Binding TemperatureWarningThresholdText, UpdateSourceTrigger=PropertyChanged}" />
                        </Grid>
                        <Grid Margin="0,8,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="190" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="진동 경고 기준" Style="{StaticResource BodyStrongText}" VerticalAlignment="Center" />
                            <TextBox Grid.Column="1" Text="{Binding VibrationWarningThresholdText, UpdateSourceTrigger=PropertyChanged}" />
                        </Grid>
                        <Grid Margin="0,8,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="190" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="습도 경고 기준" Style="{StaticResource BodyStrongText}" VerticalAlignment="Center" />
                            <TextBox Grid.Column="1" Text="{Binding HumidityWarningThresholdText, UpdateSourceTrigger=PropertyChanged}" />
                        </Grid>
                        <Grid Margin="0,8,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="190" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="자동 정지 조건" Style="{StaticResource BodyStrongText}" VerticalAlignment="Center" />
                            <StackPanel Grid.Column="1" Orientation="Horizontal">
                                <TextBox Width="58" Text="{Binding AutoShutdownWarningLimit, UpdateSourceTrigger=PropertyChanged}" />
                                <TextBlock Text=" / " VerticalAlignment="Center" Style="{StaticResource CaptionText}" />
                                <TextBox Width="58" Text="{Binding RiskWindowSeconds, UpdateSourceTrigger=PropertyChanged}" />
                                <TextBlock Text=" 초" VerticalAlignment="Center" Style="{StaticResource CaptionText}" />
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource CardBorderStyle}" Padding="12" Margin="0,10,0,0">
                    <StackPanel>
                        <DockPanel LastChildFill="False">
                            <TextBlock Text="정지 정책" Style="{StaticResource SectionTitleText}" />
                            <controls:StatusBadge DockPanel.Dock="Right" Text="보호됨" Tone="Danger" />
                        </DockPanel>

                        <Grid Margin="0,12,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="64" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="강제 정지 활성화" Style="{StaticResource BodyStrongText}" VerticalAlignment="Center" />
                            <ToggleButton Grid.Column="1" Style="{StaticResource SwitchToggleStyle}" IsChecked="True" HorizontalAlignment="Right" />
                        </Grid>
                        <Grid Margin="0,8,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="64" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="관리자 확인 필요" Style="{StaticResource BodyStrongText}" VerticalAlignment="Center" />
                            <ToggleButton Grid.Column="1" Style="{StaticResource SwitchToggleStyle}" IsChecked="True" HorizontalAlignment="Right" />
                        </Grid>
                    </StackPanel>
                </Border>

                    <Border Style="{StaticResource CardBorderStyle}" Padding="12" Margin="0,10,0,0">
                        <StackPanel>
                            <DockPanel LastChildFill="False">
                                <TextBlock Text="저장 설정" Style="{StaticResource SectionTitleText}" />
                                <controls:StatusBadge DockPanel.Dock="Right" Text="저장 가능" Tone="Normal" />
                            </DockPanel>

                            <Grid Margin="0,12,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="190" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="로그 보관 기간" Style="{StaticResource BodyStrongText}" VerticalAlignment="Center" />
                                <TextBox Grid.Column="1" Text="90일" />
                            </Grid>
                            <Grid Margin="0,8,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="190" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="센서 저장 주기" Style="{StaticResource BodyStrongText}" VerticalAlignment="Center" />
                                <TextBox Grid.Column="1" Text="{Binding SensorSnapshotSaveIntervalSeconds, UpdateSourceTrigger=PropertyChanged}" />
                            </Grid>
                        </StackPanel>
                    </Border>
                </StackPanel>
        </Grid>
        </StackPanel>
    </ScrollViewer>
</UserControl>
